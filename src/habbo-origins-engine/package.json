{
  "name": "shockless-engine",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:webhook": "node tools/dev/send-discord-webhook.mjs",
    "visual:assets:306": "node tools/build-visual-bitmap-assets.mjs --version release306",
    "external:assets:306": "node tools/materialize-external-bitmaps.mjs --version release306",
    "lingo:verify": "tsx tools/lingo-verify.ts",
    "lingo:index": "tsx tools/lingo-index.ts",
    "lingo:generate": "tsx tools/lingo-generate.ts"
  },
  "dependencies": {
    "jpeg-js": "^0.4.4",
    "pixi.js": "^8.9.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "playwright": "^1.60.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
