{
  "name": "habbpy-v4-shockless",
  "version": "0.1.0",
  "private": true,
  "description": "RuneLite-style Habbpy v4 shell for Shockless Engine",
  "type": "module",
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron:dev": "npm run build:main && electron dist/main/main/main.js",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run typecheck && npm run build:main && npm run build:renderer",
    "generate:premade-plugins": "node --import tsx scripts/generate-premade-plugin-sources.mjs",
    "package:portable": "npm run build && npm run generate:premade-plugins && node scripts/package-portable.mjs && node scripts/verify-portable-package.mjs",
    "verify:portable": "node scripts/verify-portable-package.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.main.json --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "screenshot:shell": "node scripts/screenshot-shell.mjs",
    "screenshot:renderer": "node scripts/screenshot-renderer-headless.mjs",
    "automation:electron": "node scripts/run-electron-automation.mjs",
    "automation:visible": "node scripts/run-visible-electron-smoke.mjs",
    "automation:gardening": "node scripts/run-gardening-electron-smoke.mjs",
    "automation:chooser-rights": "node scripts/run-chooser-rights-live-proof.mjs",
    "automation:plugins": "node scripts/run-plugin-live-matrix.mjs",
    "webhook": "node scripts/send-webhook.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "electron": "^32.3.3",
    "playwright": "^1.49.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vite": "^6.0.3"
  }
}
